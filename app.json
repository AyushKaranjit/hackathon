{
  "expo": {
    "name": "NagarikVerify",
    "slug": "nagarik-verify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "nagarikverify",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "NagarikVerify needs camera access to scan government documents and take selfies for verification.",
        "NSPhotoLibraryUsageDescription": "NagarikVerify needs photo library access to upload government document images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.CAMERA"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "NagarikVerify needs camera access to scan documents and verify identity."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NagarikVerify needs photo library access to upload document images."
        }
      ]
    ]
  }
}
